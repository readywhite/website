# Copy to .env locally for Railway/API testing.
# Never commit the real Private Integration Token/API key.
GHL_PRIVATE_INTEGRATION_TOKEN=replace-with-your-private-integration-token
GHL_LOCATION_ID=wXwmRjNVCUq1DCIy4Lqc
GHL_PIPELINE_ID=wtwJBdMmtrUDQX0PU5Z7
# Optional: send new opportunities directly to a specific pipeline stage.
GHL_PIPELINE_STAGE_ID=replace-with-new-lead-stage-id
# Optional: lock browser submissions to the Squarespace domain.
ALLOWED_ORIGIN=https://your-squarespace-domain.com
# Optional: customize how contacts are updated in GHL.
GHL_CONTACT_ENDPOINT=/contacts/upsert
GHL_CONTACT_TAGS=Website Lead,Property Refresh,Interior Estimate,ready-white
# Optional: used by scripts/find-ghl-form-id.sh for local form lookup only.
GHL_API_KEY=replace-with-your-private-integration-token
GHL_API_VERSION=2023-02-21
GHL_API_BASE=https://services.leadconnectorhq.com
