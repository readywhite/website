# Never commit your real Private Integration Token.
GHL_PRIVATE_INTEGRATION_TOKEN=pit_your_private_integration_token_here

# Required for contact upsert.
GHL_LOCATION_ID=your_highlevel_location_id

# Optional: set both values to create an opportunity after the contact is upserted.
GHL_PIPELINE_ID=your_ready_white_pipeline_id
GHL_PIPELINE_STAGE_ID=your_new_lead_stage_id

# Optional: write the GHL setup report to a file instead of stdout.
GHL_REPORT_OUTPUT=reports/ghl-setup-report.md

# Optional: Railway backend URL for live smoke tests. Do not point this at Squarespace unless Squarespace proxies backend routes.
READYWHITE_RAILWAY_BASE_URL=https://your-railway-domain

# Optional fallback used by CI smoke tests when READYWHITE_RAILWAY_BASE_URL is not set.
READYWHITE_BASE_URL=https://your-railway-domain
