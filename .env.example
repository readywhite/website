# Never commit your real Private Integration Token.
GHL_PRIVATE_INTEGRATION_TOKEN=pit_your_private_integration_token_here

# Required for contact upsert.
GHL_LOCATION_ID=your_highlevel_location_id

# Optional: set both values to create an opportunity after the contact is upserted.
GHL_PIPELINE_ID=your_ready_white_pipeline_id
GHL_PIPELINE_STAGE_ID=your_new_lead_stage_id

# Optional operational check endpoints. RAILWAY_HEALTH_URL should point at the deployed /health route.
RAILWAY_HEALTH_URL=https://your-railway-domain.up.railway.app/health
SQUARESPACE_FORM_URL=https://your-squarespace-domain.com
