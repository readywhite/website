# Never commit your real Private Integration Token.
GHL_PRIVATE_INTEGRATION_TOKEN=pit_your_private_integration_token_here

# Required for contact upsert.
GHL_LOCATION_ID=your_highlevel_location_id

# Optional: set both values to create an opportunity after the contact is upserted.
GHL_PIPELINE_ID=your_ready_white_pipeline_id
GHL_PIPELINE_STAGE_ID=your_new_lead_stage_id

# Optional: default tags added to every contact if the incoming payload does not override them.
GHL_CONTACT_TAGS=source:squarespace,lead:new

# Optional: include live Railway health in npm run ops:check.
RAILWAY_HEALTH_URL=https://your-railway-domain/health

# Optional: restrict browser submissions to the Squarespace marketing domain.
ALLOWED_ORIGIN=https://your-squarespace-domain.com
