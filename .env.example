# Never commit your real Private Integration Token.
GHL_PRIVATE_INTEGRATION_TOKEN=pit_your_private_integration_token_here

# Required for contact upsert.
GHL_LOCATION_ID=your_highlevel_location_id

# Optional: set both values to create an opportunity after the contact is upserted.
GHL_PIPELINE_ID=your_ready_white_pipeline_id
GHL_PIPELINE_STAGE_ID=your_new_lead_stage_id

# Required for automated photo analysis. Keep server-side only.
OPENAI_API_KEY=sk_your_openai_api_key_here

# Optional: override the default OpenAI vision-capable model used by /api/photo-estimate.
OPENAI_VISION_MODEL=gpt-4.1-mini

# Optional operational source-of-truth and admin controls
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
ADMIN_API_TOKEN=replace-with-strong-admin-token
OPS_API_TOKEN=replace-with-ops-token
VENDOR_OPS_API_TOKEN=replace-with-vendor-ops-token
OPS_READ_API_TOKEN=replace-with-read-only-ops-token

# Required to let /api/photo-estimate sign server-owned pricing before /api/ghl-lead trusts it.
ESTIMATE_SIGNING_SECRET=replace-with-strong-estimate-signing-secret

# Required when returning absolute protected photo URLs from Railway.
PUBLIC_BASE_URL=https://your-ready-white-railway-domain.example

# Optional live ops dashboard snapshot input. Do not use example snapshots in production dashboards.
OPS_SNAPSHOT_JSON=
OPS_SNAPSHOT_PATH=
ALLOW_EXAMPLE_OPS_DASHBOARD=false
